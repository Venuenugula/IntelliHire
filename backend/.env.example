# Runtime uses the POOLED endpoint (async). On Neon this host ends in "-pooler".
DATABASE_URL=postgresql+asyncpg://delulu:delulu@localhost:5432/delulu
DATABASE_URL_SYNC=postgresql://delulu:delulu@localhost:5432/delulu
# Alembic/DDL uses the DIRECT (unpooled) endpoint — same host WITHOUT "-pooler".
# DDL must not run through PgBouncer transaction pooling. If unset, falls back to
# DATABASE_URL_SYNC (backward compatible).
DIRECT_URL=postgresql://delulu:delulu@localhost:5432/delulu
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
GEMINI_API_KEY=your-gemini-api-key-here
UPLOAD_DIR=./uploads
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=true

# GitHub evidence (required for teammate REST extractor + deep pipeline)
GITHUB_TOKEN=your-github-token-here
# github_intel cache store. SQLite for zero-setup local dev; in production point at
# the Neon SYNC url (schema-qualified tables are pooler-safe) — it lives in its own
# schema (GITHUB_INTEL_SCHEMA) with its own Alembic tree (alembic_gh.ini).
GITHUB_INTEL_DB_URL=sqlite:///./github_intel.db
GITHUB_INTEL_SCHEMA=github_intel
TOP_N_REPOS=3
MAX_FETCH_FILES=40
FETCH_GIT_HISTORY_FOR_ALL=false

# Optional LLM for LinkedIn extraction
OPENAI_API_KEY=

# LinkedIn evidence (Apify LinkedIn profile scraper).
# Without this, LinkedIn shows as "not available" — GitHub/LeetCode/Resume still work.
# Free Apify accounts are capped at ~10 actor runs; upgrade for higher throughput.
APIFY_TOKEN=your-apify-token-here

# Document Intelligence
PII_POLICY=mask_external
OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_BUCKET=delulu-documents
# OBJECT_STORAGE_ENDPOINT=http://localhost:9000
# OBJECT_STORAGE_ACCESS_KEY=
# OBJECT_STORAGE_SECRET_KEY=
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash
